{
  "name": "rofi-switcher",
  "version": "0.1.0",
  "description": "A window switcher and launcher inspired by Rofi",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "prepare": "husky",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --config .eslintrc.json",
    "format": "prettier --write 'src/**/*.ts' 'src/**/*.tsx'"
  },
  "dependencies": {
    "@plasmohq/messaging": "^0.7.0",
    "@plasmohq/storage": "^1.8.0",
    "plasmo": "^0.90.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "wi-condition-builder": "^1.9.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npm run lint",
      "npm run format"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@types/chrome": "^0.2.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^7.17.0",
    "@typescript-eslint/parser": "^7.17.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-perfectionist": "^4.6.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.35.0",
    "husky": "^9.1.3",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.3",
    "typescript": "^5.3.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "husky",
      "lmdb",
      "msgpackr-extract",
      "sharp"
    ]
  },
  "manifest": {
    "name": "Rofi Switcher",
    "version": "0.1.0",
    "description": "A window switcher and launcher inspired by Rofi",
    "commands": {
      "toggle-rofi": {
        "suggested_key": {
          "default": "Ctrl+Space"
        },
        "description": "Toggle Rofi overlay"
      }
    },
    "permissions": [
      "tabs",
      "tabGroups",
      "storage"
    ],
    "optional_permissions": [
      "history"
    ],
    "host_permissions": [
      "<all_urls>"
    ]
  }
}
